{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:chromium": "npx playwright test --config=e2e/playwright.config.ts --project=chromium",
    "test:e2e:headed": "npx playwright test --config=e2e/playwright.config.ts --headed --project=chromium",
    "test:all": "vitest run && npx playwright test --config=e2e/playwright.config.ts --project=chromium"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
